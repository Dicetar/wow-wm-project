    { "key": "mod-wm-bridge", "source": "native_modules/mod-wm-bridge", "target_path": "src/modules/mod-wm-bridge" }
  ],
  "dependencies": [
    {
      "key": "boost",
      "type": "installer",
      "url": "https://github.com/userdocs/boost/releases/download/boost-1.87.0/boost_1_87_0-msvc-14.3-64.exe",
      "filename": "boost_1_87_0-msvc-14.3-64.exe",
      "target_path": "deps/boost_1_87_0",
      "required_marker": "boost/version.hpp",
      "silent_args": [
        "/SP-",
        "/VERYSILENT",
        "/SUPPRESSMSGBOXES",
        "/NORESTART",
        "/DIR={InstallDir}"
      ]
    },
    {
      "key": "openssl",
      "type": "installer",
      "url": "https://slproweb.com/download/Win64OpenSSL-3_6_1.exe",
      "filename": "Win64OpenSSL-3_6_1.exe",
      "target_path": "deps/openssl",
      "required_marker": "include/openssl/opensslv.h",
      "silent_args": [
        "/SP-",
        "/VERYSILENT",
        "/SUPPRESSMSGBOXES",
        "/NORESTART",
        "/DIR={InstallDir}"
      ]
    },
    {
      "key": "mysql",
      "type": "archive",
      "url": "https://cdn.mysql.com/archives/mysql-8.4/mysql-8.4.7-winx64.zip",
      "filename": "mysql-8.4.7-winx64.zip",
      "target_path": "deps/mysql",
      "required_marker": "bin/libmysql.dll",
      "extracted_subdir": "mysql-8.4.7-winx64"
    }
  ],
  "stage_assets": [
    { "source": "wow_addons/WMBridge", "target": "run/assets/wow_addons/WMBridge", "kind": "directory" },
    { "source": "sql/bootstrap", "target": "run/sql/bootstrap", "kind": "directory" },
    { "source": "sql/repack", "target": "run/sql/repack", "kind": "directory" },
    { "source": ".env.example", "target": "run/configs/.env.example", "kind": "file" },
    { "source": "bootstrap/templates/README.txt", "target": "run/configs/README.txt", "kind": "file" },
    { "source": "scripts/bootstrap/Test-RuntimeDllGuard.ps1", "target": "run/helpers/Test-RuntimeDllGuard.ps1", "kind": "file" },
    { "source": "scripts/repack/Apply-RepackCompatibilityOverlay.ps1", "target": "run/helpers/Apply-RepackCompatibilityOverlay.ps1", "kind": "file" }
  ],
  "sql_overrides": [
    { "source": "sql/repack/db_auth", "target": "data/sql/custom/db_auth" },
    { "source": "sql/repack/db_characters", "target": "data/sql/custom/db_characters" },
    { "source": "sql/repack/db_world", "target": "data/sql/custom/db_world" }
  ],
  "build": {
    "generator_arch": "x64",
    "configuration": "RelWithDebInfo",
    "build_shared_libs": false
  }
}
