WM_ENV=dev
WM_LOG_LEVEL=INFO

WM_WORLD_DB_HOST=127.0.0.1
WM_WORLD_DB_PORT=3306
WM_WORLD_DB_NAME=acore_world
WM_WORLD_DB_USER=root
WM_WORLD_DB_PASSWORD=CHANGE_ME

WM_CHAR_DB_HOST=127.0.0.1
WM_CHAR_DB_PORT=3306
WM_CHAR_DB_NAME=acore_characters
WM_CHAR_DB_USER=root
WM_CHAR_DB_PASSWORD=CHANGE_ME

WM_SOAP_ENABLED=0
WM_SOAP_HOST=127.0.0.1
WM_SOAP_PORT=7878
WM_SOAP_USER=soap
WM_SOAP_PASSWORD=CHANGE_ME
WM_SOAP_PATH=/

WM_EVENT_DEFAULT_QUESTGIVER_ENTRY=
WM_EVENT_FOLLOWUP_KILL_COUNT=6
WM_EVENT_DEFAULT_REWARD_MONEY_COPPER=1200

WM_ADDON_LOG_PATH=.wm-bootstrap\run\logs\WMOps.log
WM_ADDON_LOG_BATCH_SIZE=200
WM_ADDON_CHANNEL_NAME=WMBridgePrivate
WM_ADDON_PREFIX=WMBRIDGE

WM_NATIVE_BRIDGE_BATCH_SIZE=200
WM_NATIVE_BRIDGE_ACTION_WAIT_SECONDS=5.0
WM_NATIVE_BRIDGE_ACTION_POLL_SECONDS=0.25
WM_BRIDGE_CONFIG_PATH=.wm-bootstrap\run\configs\modules\mod_wm_bridge.conf

WM_CONTROL_ROOT=control
WM_CONTROL_PROPOSAL_STATE_PATH=.wm-bootstrap\state\control-proposals
# LLM-authored live apply is blocked unless this is set to 1.
WM_LLM_DIRECT_APPLY=0

WM_COMBAT_LOG_PATH=.wm-bootstrap\run\logs\WoWCombatLog.txt
WM_COMBAT_LOG_BATCH_SIZE=200
WM_COMBAT_LOG_PLAYER_NAME=
