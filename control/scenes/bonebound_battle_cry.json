      "payload": {
        "arc_key": "scene:{scene_id}:{player_guid}:{run_key}",
        "text": "raises a rusted blade in answer."
      },
      "risk_level": "low",
      "idempotency_suffix": "emote",
      "expected_effect": "The WM-owned creature performs a text emote."
    },
    {
      "native_action_kind": "player_apply_aura",
      "payload": {
        "spell_id": 687
      },
      "risk_level": "medium",
      "idempotency_suffix": "buff",
      "expected_effect": "The scoped player receives a short visible rally buff."
